{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run scripts/build-bun.ts",
    "lint": "eslint \"{src,scripts}/**/*.{ts,tsx}\"",
    "preview": "bunx --bun vite preview",
    "lint:fix": "eslint \"{src,scripts}/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"{src,scripts}/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"{src,scripts}/**/*.{ts,tsx,json,css}\"",
    "test": "bun test",
    "test:cov": "bun test --coverage",
    "test:watch": "bun test --watch",
    "build:vite": "bunx --bun vite build",
    "build:prod": "bun run scripts/build-bun.ts",
    "type-check": "bunx --bun tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "^20.8.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.1",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.3",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "3.4.10",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  }
}
