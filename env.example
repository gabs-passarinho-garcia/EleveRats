# ==========================================
# 🛡️ ZERO TRUST (CLOUDFLARE)
# ==========================================
# Token gerado no painel da Cloudflare (Zero Trust > Networks > Tunnels)
CF_TUNNEL_TOKEN=seu_token_do_cloudflare_tunnel_aqui

# ==========================================
# 🐘 BANCO DE DADOS (POSTGRESQL)
# ==========================================
# Credenciais do banco principal
DB_USER=gabs_admin
DB_PASSWORD=senha_segura_do_banco_de_dados_aqui

# ==========================================
# 📦 STORAGE (MINIO)
# ==========================================
# Credenciais para acessar o painel e a API do MinIO
MINIO_USER=admin_storage
MINIO_PASSWORD=senha_segura_do_storage_aqui

# ==========================================
# 📱 WHATSAPP (META API)
# ==========================================
# Tokens necessários para o n8n ou a Minimal API se comunicarem com a Meta
META_API_TOKEN=seu_token_de_acesso_permanente_da_meta_aqui
META_WEBHOOK_VERIFY_TOKEN=seu_token_de_verificacao_do_webhook_aqui
META_PHONE_NUMBER_ID=seu_id_do_numero_de_telefone_aqui
