{
  "version": "0.2.0",
  "configurations": [
    {
      // Setup for .NET Core Launch (Web)
      "name": ".NET Core Launch (web)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      // Main executable path for .NET 10
      "program": "${workspaceFolder}/backend/bin/Debug/net10.0/EleveRats.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend",
      "stopAtEntry": false,
      // Opens browser on server start
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      },
      // Pipe transport configuration for netcoredbg on Linux
      "pipeTransport": {
        "pipeCwd": "${workspaceFolder}/backend",
        "pipeProgram": "bash",
        "pipeArgs": ["-c"],
        // Absolute path to the netcoredbg executable
        "debuggerPath": "/mnt/dados/Gabriel/Projetos/netcoredbg-linux-amd64/netcoredbg/netcoredbg"
      }
    },
    {
      "name": ".NET Core Attach",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}