root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
#### --- Cabeçalho e Identidade --- ####

# Template para o time EleveRats (2026)
file_header_template = Copyright (C) 2026 Gabriel Passarinho Garcia and EleveRats Team\nThis program is free software: you can redistribute it and/or modify\nit under the terms of the GNU Affero General Public License as\npublished by the Free Software Foundation, either version 3 of the\nLicense, or (at your option) any later version.

#### --- Organização e Estilo Moderno --- ####

# Usings: Organizados e fora do namespace
dotnet_separate_import_directive_groups = false
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:warning

# Namespaces: Estilo C# 10+ (File-scoped)
csharp_style_namespace_declarations = file_scoped:error

# Expression-bodied members: Limpeza visual onde faz sentido
csharp_style_expression_bodied_methods = when_on_single_line:warning
csharp_style_expression_bodied_constructors = when_on_single_line:warning
csharp_style_expression_bodied_operators = when_on_single_line:warning
csharp_style_expression_bodied_properties = true:warning
csharp_style_expression_bodied_accessors = true:warning
csharp_style_expression_bodied_lambdas = true:warning
csharp_style_expression_bodied_local_functions = true:warning

# Novidades do C# 12 (Primary Constructors e Collection Expressions)
csharp_style_prefer_primary_constructors = true:suggestion
csharp_style_prefer_collection_expression = true:warning

#### --- Tipagem e Segurança --- ####

# Strict Typing: var apenas quando o tipo está na cara (Ex: var x = new List<int>())
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = true:warning
csharp_style_var_elsewhere = false:warning

# Nullability e Tuplas
dotnet_style_explicit_tuple_names = true:warning
dotnet_style_null_check_before_type_check = true:warning

# Ordem dos Modificadores (O padrão da indústria)
csharp_preferred_modifier_order = public,private,protected,internal,file,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:warning

#### --- Convenções de Nomenclatura (Naming) --- ####

# Interfaces com "I"
dotnet_naming_rule.interface_should_be_begun_with_i.severity = error
dotnet_naming_rule.interface_should_be_begun_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begun_with_i.style = begun_with_i

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = *
dotnet_naming_style.begun_with_i.required_prefix = I
dotnet_naming_style.begun_with_i.capitalization = pascal_case

# Campos Privados com "_" (Padrão sugerido para evitar conflito com variáveis locais)
dotnet_naming_rule.private_members_with_underscore.severity = warning
dotnet_naming_rule.private_members_with_underscore.symbols = private_fields
dotnet_naming_rule.private_members_with_underscore.style = prefix_underscore

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.prefix_underscore.required_prefix = _
dotnet_naming_style.prefix_underscore.capitalization = camel_case

#### --- Silenciadores de Regras Chatas (The Referee Whistle) --- ####

# SA1633: Cabeçalho obrigatório (StyleCop)
dotnet_diagnostic.SA1633.severity = warning

# CA1812: Classes internas instanciadas por Reflection (EF Core/DI)
dotnet_diagnostic.CA1812.severity = none

# CA2007: ConfigureAwait(false) - Desnecessário em ASP.NET Core moderno
dotnet_diagnostic.CA2007.severity = none

# CA1303: Literais em logs (Não precisamos de tradução para logs de console)
dotnet_diagnostic.CA1303.severity = none

# CA1031: Catch general exception types (Útil em BackgroundServices resilientes)
dotnet_diagnostic.CA1031.severity = none

# Desativar exigências de doc XML chatas (StyleCop)
dotnet_diagnostic.SA1600.severity = none
dotnet_diagnostic.SA1602.severity = none
dotnet_diagnostic.SA1623.severity = none
dotnet_diagnostic.CS1591.severity = warning
# SA1009: Closing parenthesis should not be preceded by a space
dotnet_diagnostic.SA1009.severity = none

# SA1111: Closing parenthesis should be on line of last parameter
dotnet_diagnostic.SA1111.severity = none

# SA1028: Code should not contain trailing whitespace (Às vezes o CSharpier deixa uns espaços que o StyleCop odeia)
dotnet_diagnostic.SA1028.severity = none

# SA1513: Closing brace should be followed by blank line (Outro que costuma brigar)
dotnet_diagnostic.SA1513.severity = none

# Estética (O CSharpier cuida disso, o compilador não precisa gritar)
dotnet_diagnostic.SA1101.severity = none
dotnet_diagnostic.IDE0005.severity = suggestion

#### --- Exceções: Código Autogerado (Migrations e Designer) --- ####

[**/Migrations/*.{cs,designer.cs}]
generated_code = true
dotnet_analyzer_diagnostic.severity = none
