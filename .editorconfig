root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
#### Core Design Rules ####

# Organize usings
dotnet_separate_import_directive_groups = false
dotnet_sort_system_directives_first = true
file_header_template = Copyright (C) 2026 Gabriel Passarinho Garcia and EleveRats Team\nThis program is free software: you can redistribute it and/or modify\nit under the terms of the GNU Affero General Public License as\npublished by the Free Software Foundation, either version 3 of the\nLicense, or (at your option) any later version.

# Style Rules
csharp_style_namespace_declarations = file_scoped:error
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = when_on_single_line:suggestion
csharp_style_expression_bodied_operators = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion
csharp_style_expression_bodied_lambdas = true:suggestion
csharp_style_expression_bodied_local_functions = true:suggestion

# Nullability
dotnet_style_explicit_tuple_names = true:suggestion
dotnet_style_null_check_before_type_check = true:suggestion

# Naming conventions
dotnet_naming_rule.interface_should_be_begun_with_i.severity = error
dotnet_naming_rule.interface_should_be_begun_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begun_with_i.style = begun_with_i

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = *

dotnet_naming_style.begun_with_i.required_prefix = I
dotnet_naming_style.begun_with_i.capitalization = pascal_case

#### Linter & Analyzer Silencing (The Referee Whistle) ####

# Disable missing XML comment warnings for publicly visible type or member (Compiler)
dotnet_diagnostic.CS1591.severity = none

# Disable "Elements should be documented" (StyleCop)
dotnet_diagnostic.SA1600.severity = none

# Disable "Enumeration items should be documented" (StyleCop)
dotnet_diagnostic.SA1602.severity = none

# Disable "The property's documentation summary text should begin with: 'Gets'" (StyleCop)
dotnet_diagnostic.SA1623.severity = none

# Disable strict file header checks (to avoid conflicts with your custom AGPL header) (StyleCop)
dotnet_diagnostic.SA1633.severity = none