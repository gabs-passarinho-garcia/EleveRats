root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
#### Core Design Rules ####

# Organize usings
dotnet_separate_import_directive_groups = false
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:warning

# Header Template (Native IDEs auto-generation)
file_header_template = Copyright (C) 2026 Gabriel Passarinho Garcia and EleveRats Team\nThis program is free software: you can redistribute it and/or modify\nit under the terms of the GNU Affero General Public License as\npublished by the Free Software Foundation, either version 3 of the\nLicense, or (at your option) any later version.

# Style Rules
csharp_style_namespace_declarations = file_scoped:error
csharp_style_expression_bodied_methods = when_on_single_line:warning
csharp_style_expression_bodied_constructors = when_on_single_line:warning
csharp_style_expression_bodied_operators = when_on_single_line:warning
csharp_style_expression_bodied_properties = true:warning
csharp_style_expression_bodied_accessors = true:warning
csharp_style_expression_bodied_lambdas = true:warning
csharp_style_expression_bodied_local_functions = true:warning

# Nullability
dotnet_style_explicit_tuple_names = true:warning
dotnet_style_null_check_before_type_check = true:warning

# Strict Modifier Order
csharp_preferred_modifier_order = public,private,protected,internal,file,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:warning

# Strict Typing (No implicit typing where not obvious)
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = true:warning
csharp_style_var_elsewhere = false:warning

# Naming conventions
dotnet_naming_rule.interface_should_be_begun_with_i.severity = error
dotnet_naming_rule.interface_should_be_begun_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begun_with_i.style = begun_with_i

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = *

dotnet_naming_style.begun_with_i.required_prefix = I
dotnet_naming_style.begun_with_i.capitalization = pascal_case

#### Linter & Analyzer Silencing (The Referee Whistle) ####

# SA1633: Strict file header checks - ENABLED to work with stylecop.json
dotnet_diagnostic.SA1633.severity = warning

# Disable "Enumeration items should be documented" (StyleCop - Optional flexibility)
dotnet_diagnostic.SA1602.severity = none

# Disable "The property's documentation summary text should begin with: 'Gets'" (StyleCop - Too pedantic)
dotnet_diagnostic.SA1623.severity = none

# Disable "Prefix local calls with this" (StyleCop - Clutters modern C# code)
dotnet_diagnostic.SA1101.severity = none

#### The Referee Silencer (Microsoft Pedantic Rules) ####

# CA1812: Internal class that is apparently never instantiated.
# Motivo: O EF Core instancia os Models e Configurations via Reflection. O compilador não vê isso e acha que a classe é inútil.
dotnet_diagnostic.CA1812.severity = none

# CA2007: Consider calling ConfigureAwait on the awaited task.
# Motivo: Em ASP.NET Core moderno, não existe SynchronizationContext. Usar ConfigureAwait(false) hoje em dia no back-end é poluição visual desnecessária.
dotnet_diagnostic.CA2007.severity = none

# CA1303: Do not pass literals as localized parameters.
# Motivo: Ele tá reclamando do seu Console.WriteLine no AntiIdlenessService, pedindo pra você criar um arquivo de tradução só pra dar um log no terminal. Esquece isso.
dotnet_diagnostic.CA1303.severity = none

# CA1031: Do not catch general exception types.
# Motivo: No seu AntiIdlenessService, você provavelmente fez um 'catch (Exception ex)'. O C# odeia isso, mas em BackgroundServices de resiliência, às vezes é necessário.
dotnet_diagnostic.CA1031.severity = none # Remover depois

dotnet_diagnostic.SA1600.severity = none
dotnet_diagnostic.CS1591.severity = warning

# (Bônus) Para não cobrar documentação em propriedades auto-implementadas:
dotnet_style_require_accessibility_modifiers = always:warning

#### Ignorar Código Autogerado (Migrations) ####
[**/Migrations/*.{cs,designer.cs}]
generated_code = true
dotnet_analyzer_diagnostic.severity = none

